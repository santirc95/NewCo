# Genera el secret con: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Airtable (Cap.2) — al definir ambos, la capa de datos cambia a Airtable:
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# Dominio público de los links de propuesta al cliente (nunca marca NewCo)
# Ej.: https://propuestas.tudominio.com — sin él, cae al origin actual (dev)
NEXT_PUBLIC_PROPOSAL_BASE_URL=
